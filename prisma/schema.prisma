generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  twitterId    String   @unique
  username     String
  displayName  String
  avatar       String?
  wallet       String?
  twitterToken String?
  twitterTokenSecret String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
